extends default

block content
  h2(style="text-align: center;") Add Account

  form(method="get", style="max-width: 400px; margin: 30px auto; padding: 20px; background-color: #f9f9f9; border-radius: 8px; box-shadow: 0 0 8px rgba(0,0,0,0.1);")
    label(for="username") Username:
    input(name="username", type="text", required=true)
    br
    br
    label(for="password") Password:
    input(name="password", type="password", required=true)
    br
    br
    input(name="submit", type="submit", value="Add Account")

  if errorMessage
    div(style="color:red; margin-top:10px; text-align: center;") !{errorMessage}

  div(style="margin-top:20px; max-width: 600px; margin-left: auto; margin-right: auto;")
    table(border="1", cellpadding="5", cellspacing="0", style="border-collapse:collapse; width: 100%; font-family: Arial, sans-serif;")
      thead
        tr
          th(style="background-color: #f0f0f0; padding: 8px 12px; text-align: left;") Username
          th(style="background-color: #f0f0f0; padding: 8px 12px; text-align: left;") Password
      tbody
        each user, i in users
          tr(style= i % 2 === 0 ? "background-color:#fafafa;" : "")
            td(style="padding: 8px 12px; border: 1px solid #ccc;") #{user.username}
            td(style="padding: 8px 12px; border: 1px solid #ccc;") #{user.password}
